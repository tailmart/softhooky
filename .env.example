# .env.example

# Image Generation API Key (from https://api.xgapi.top)
IMAGE_GEN_API_KEY=

# MySQL Database Configuration (Hostinger)
DB_HOST=your_db_host
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# Cloudflare R2 Configuration
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=your_bucket_name
R2_PUBLIC_URL=https://static.softhooky.com

# Email Configuration (SMTP)
EMAIL_PASS=your_smtp_password

# Payment Gateway Configuration
WX_APPID=your_wechat_appid
WX_SECRET=your_wechat_secret
ALI_APPID=your_alipay_appid
ALI_SECRET=your_alipay_secret
PAYMENT_API_URL=https://api.dpweixin.com/payment/do.html

# Frontend and Backend URLs
BACKEND_URL=https://softhooky.com
FRONTEND_URL=https://softhooky.com

# Application URL
APP_URL=https://softhooky.com

# Admin Backend API URL (现在使用主应用后端)
VITE_ADMIN_API_URL=https://softhooky.com

# Main App API URL (用于前端请求后端 API，部署时留空使用相对路径)
VITE_API_URL=
