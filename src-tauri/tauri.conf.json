{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema.json",
  "productName": "Softhooky",
  "version": "1.0.5",
  "identifier": "com.softhooky.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3001",
    "beforeDevCommand": "",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Softhooky",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../server.cjs",
      "../dist/**/*",
      "../.env*",
      "../*.traineddata"
    ],
    "windows": {
      "wix": null,
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/128x128.png",
        "sidebarImage": "icons/128x128@2x.png",
        "languages": ["SimpChinese", "English"]
      }
    },
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  },
  "plugins": {
    "shell": {
      "open": true,
      "scope": [
        {
          "name": "node",
          "cmd": "node",
          "args": [
            { "validator": "\\S+" }
          ]
        }
      ]
    },
    "updater": {
      "active": true,
      "endpoints": [
        "http://43.143.213.221/updates/target.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNCMTJCNDBEOUE0NkFCQTkKUldTcHEwYWFEYlFTTzVOLzdJS041M0dUQmptUUZ5SSs0YlZkWmZBZzVBaHVPNFBqTkN2Rmt2disK"
    }
  }
}
