    "aj-captcha-react": "^1.3.4",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "busboy": "^1.6.0",
    "compression": "^1.8.1",
    "cos-nodejs-sdk-v5": "^2.15.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "form-data": "^4.0.5",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "mysql2": "^3.19.0",
