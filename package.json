  "description": "Softhooky",
  "author": "Softhooky",
  "type": "module",
  "scripts": {
    "dev": "tsx watch server.ts",
    "build": "vite build && node build-server.js",
    "start": "node server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "migrate": "tsx run-migrations.ts",
    "publish": "node publish.js",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:mac": "tauri build --target universal-apple-darwin",
    "tauri:build:win": "tauri build --target x86_64-pc-windows-msvc",
    "tauri:icons": "node src-tauri/generate-icons.mjs",
    "tauri:publish": "node publish-tauri.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1003.0",
